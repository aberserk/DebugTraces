#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-origin}"
remote_url="${2:-}"

if [[ "${SKIP_PRE_PUSH:-0}" == "1" ]]; then
  echo "[pre-push] SKIP_PRE_PUSH=1; skipping checks"
  exit 0
fi

check_conflicts_in_commit() {
  local commit="$1"
  if git grep -nE "^(<<<<<<<|=======|>>>>>>>)" "$commit" -- . >/dev/null 2>&1; then
    echo "[pre-push] conflict markers detected in commit $commit" >&2
    git grep -nE "^(<<<<<<<|=======|>>>>>>>)" "$commit" -- . >&2 || true
    return 1
  fi
}

fail=0
while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -n "${local_ref:-}" ]] || continue

  # Deletions have all-zero local SHA.
  if [[ "$local_sha" =~ ^0+$ ]]; then
    continue
  fi

  if [[ "$remote_sha" =~ ^0+$ ]]; then
    commits="$(git rev-list "$local_sha" --not --remotes)"
  else
    commits="$(git rev-list "${remote_sha}..${local_sha}")"
  fi

  for commit in $commits; do
    check_conflicts_in_commit "$commit" || fail=1
    if ! git show --check --pretty="" "$commit" >/dev/null; then
      echo "[pre-push] whitespace or patch-format issues in commit $commit" >&2
      git show --check --pretty="" "$commit" >&2 || true
      fail=1
    fi
  done
done

if [[ "$fail" -ne 0 ]]; then
  echo "[pre-push] aborting push due to commit hygiene failures" >&2
  exit 1
fi

current_branch="$(git symbolic-ref --quiet --short HEAD || true)"
if [[ "$current_branch" == "main" ]] && git rev-parse --verify --quiet @{u} >/dev/null; then
  read -r upstream_only local_only < <(git rev-list --left-right --count @{u}...HEAD)
  if (( upstream_only > 0 )); then
    echo "[pre-push] local main is behind upstream by ${upstream_only} commit(s); pull/rebase before pushing" >&2
    exit 1
  fi
fi

if [[ -x scripts/check_api_abi.sh ]]; then
  echo "[pre-push] running scripts/check_api_abi.sh"
  scripts/check_api_abi.sh
fi

echo "[pre-push] checks passed for ${remote_name} ${remote_url}"
